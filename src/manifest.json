{
  "manifest_version": 3,
  "name": "__MSG_Name__",
  "version": "1.8.4.38",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "permissions": [
    "storage", 
    "contextMenus", 
    "activeTab", 
    "history",
    "bookmarks", 
    "clipboardRead",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [{
    "resources": [
      "donate.html", 
      "js/donate.js",
      "manager.html", 
      "js/manager.js", 
      "js/loader.js",
	  "js/modules/shared.js", 	  
      "js/modules/theme.js",  
      "js/modules/crypto-wrapper.js",
      "js/modules/manager-lock.js",
      "js/modules/manager-folders.js",
      "js/modules/manager-bookmarks.js",
      "js/modules/popup-html-importer.js", 
      "js/modules/popup-history-cleaner.js",
      "js/modules/popup-import-export-manager.js",
      "js/modules/popup-drag-drop.js",
      "js/modules/popup-auth.js",
      "js/modules/popup-ui.js",
      "js/modules/popup-tree.js",
      "js/modules/popup-bookmarks.js",
	  "js/modules/donation-reminder.js",
      "icons/*.png"
    ],
    "matches": ["chrome-extension://*/*"]
  }],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}